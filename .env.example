# Backend
MIS_APP_NAME=Medical Intelligence System API
MIS_APP_VERSION=0.1.0
MIS_APP_ENV=development
MIS_APP_HOST=0.0.0.0
MIS_APP_PORT=8000
MIS_LOG_LEVEL=INFO
MIS_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
MIS_DATABASE_URL=sqlite:///./data/medical_intelligence.db
MIS_REPORT_OUTPUT_DIR=./reports
MIS_LLM_PROVIDER=openrouter
MIS_LLM_API_KEY=
MIS_LLM_DEFAULT_MODEL=
MIS_LLM_REQUEST_TIMEOUT_SECONDS=60
MIS_LLM_ENABLE_RESPONSE_HEALING=true
MIS_LLM_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MIS_LLM_OPENROUTER_SITE_URL=
MIS_LLM_OPENROUTER_APP_TITLE=Medical Intelligence System
MIS_FETCH_CLINICALTRIALS_MAX_RECORDS=500
MIS_FETCH_PUBMED_MAX_RECORDS=200
MIS_FETCH_QUERY_INTERVAL_SECONDS=0.5
MIS_ANALYSIS_LLM_ENRICHMENT_FULL_SCAN=false

# Frontend
VITE_API_BASE_URL=http://localhost:8000
